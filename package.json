{
  "name": "nx-turbo",
  "version": "1.0.3",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20 <25"
  },
  "private": true,
  "scripts": {
    "dev": "turbo run dev storybook --filter=!python",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "storybook": "turbo run storybook --filter=@nx/design-system",
    "build-storybook": "turbo run build-storybook --filter=@nx/design-system",
    "preview:concept-lab": "open 'packages/design-system/templates/concept-lab/ConceptLab.dc.html'"
  },
  "devDependencies": {
    "turbo": "2.10.5"
  }
}
