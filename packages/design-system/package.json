{
  "name": "@nx/design-system",
  "version": "1.0.0",
  "description": "NX Design System: tokens, components, guidelines, and templates",
  "private": false,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./styles": "./styles.css",
    "./tokens": "./dist/tokens.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "styles.css",
    "assets",
    "components",
    "guidelines",
    "tokens",
    "templates",
    "ui_kits"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "echo 'No lint configured yet'",
    "preview:concept-lab": "open templates/concept-lab/ConceptLab.dc.html",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "storybook": "^8.6.14",
    "typescript": "^5.0.0",
    "vite": "^6.3.5"
  }
}
