{
  "name": "@nx/newspaper",
  "version": "1.0.0",
  "description": "Newspaper theme system for content-rich editorial experiences",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./styles.css",
    "./tokens": {
      "types": "./dist/theme/tokens.d.ts",
      "import": "./dist/theme/tokens.js"
    }
  },
  "files": [
    "dist",
    "src",
    "styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit",
    "lint": "echo 'No lint configured yet'"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "^5.0.0"
  }
}
